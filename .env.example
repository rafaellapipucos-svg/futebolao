# ===== Obrigatorias =====
# Chave de assinatura JWT (>=32 bytes). Gere com: python3 -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=
# Pepper de senhas (>=32 bytes, NUNCA trocar depois de ter usuarios). Gere igual acima.
PEPPER=

# ===== Banco de dados =====
# Producao (Render + Supabase): cole aqui a connection string do Supabase
# (Project Settings -> Database -> Connection string -> URI).
# Use o Session Pooler (porta 5432, IPv4) ou Transaction Pooler (6543) — ambos funcionam.
# Ex.: postgresql://postgres.abcdefgh:SUASENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
# VAZIO = SQLite local em DATA_DIR (dev/testes).
DATABASE_URL=

# ===== Recomendadas =====
# URL publica (para redirect do OAuth). Ex: https://futebolao.onrender.com
PUBLIC_BASE_URL=http://localhost:8000
# E-mails que viram admin automaticamente ao entrar (separados por virgula)
ADMIN_EMAILS=rafaellapipucos@gmail.com
# Codigo de convite para registro (vazio = registro aberto)
INVITE_CODE=

# ===== Opcionais (recursos ligam sozinhos quando presentes) =====
# Google OAuth (console.cloud.google.com -> Credentials -> OAuth Client ID, tipo Web)
# Redirect URI autorizada: {PUBLIC_BASE_URL}/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Token da football-data.org (gratuito) para placares automaticos
FOOTBALL_DATA_TOKEN=

# ===== Infra =====
# Diretorio do SQLite local (ignorado quando DATABASE_URL esta definido)
DATA_DIR=./data
# true em producao (cookies Secure + HSTS)
COOKIE_SECURE=false
